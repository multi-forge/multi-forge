# ==========================================
# Forge Imager - Environment Variables
# ==========================================
# Copy this file to .env for local development
# Variables prefixed with VITE_ are exposed to the frontend
#
# .env           - Default development values
# .env.local     - Local overrides (gitignored)
# .env.production - Production build values

# App Info
VITE_APP_NAME=Forge Imager
# Note: Version is managed in tauri.conf.json and accessible via @tauri-apps/api/app

# Forge URLs (for reference - actual API calls are in Rust backend)
VITE_FORGE_WEBSITE=https://github.com/multi-forge/multi-forge
VITE_FORGE_DOCS=https://github.com/multi-forge/multi-forge
VITE_FORGE_FORUM=https://github.com/multi-forge/multi-forge/discussions
VITE_FORGE_GITHUB=https://github.com/multi-forge

# Project URLs
VITE_PROJECT_REPO=https://github.com/multi-forge/forge-imager
VITE_PROJECT_ISSUES=https://github.com/multi-forge/forge-imager/issues

# Development Settings
# Set to true to enable dev tools and debug features
VITE_DEV_TOOLS=true
VITE_DEBUG_MODE=true
